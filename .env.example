# ─── Worker Configuration ─────────────────────────────────────────────────────
WORKER_ID=worker1
WORKER_PORT=5000
REDIS_URL=redis://redis:6379

# ─── Dispatcher Configuration ─────────────────────────────────────────────────
WORKER1_URL=http://worker1:5000
WORKER2_URL=http://worker2:5000
WORKER3_URL=http://worker3:5000

# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Get from: https://console.groq.com/keys  (FREE tier available!)
GROQ_API_KEY=

# ─── Ollama (Local LLMs) ──────────────────────────────────────────────────────
# Run Ollama locally: https://ollama.ai
# Pull models: ollama pull codellama | ollama pull deepseek-coder
OLLAMA_URL=http://host.docker.internal:11434
